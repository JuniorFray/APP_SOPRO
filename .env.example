# Chave da API Gemini para processamento de intenção de voz.
# Obtenha a sua em: https://aistudio.google.com (gratuita, 1 M tokens/dia)
# Copie este arquivo para .env e preencha com a sua chave real.
# NUNCA comite o .env — ele já está no .gitignore.
GEMINI_API_KEY=sua_chave_aqui_do_aistudio.google.com

# Chave da LocationIQ para geocoding (Camada 2 — 5.000 req/dia gratis).
# Obtenha a sua em: https://locationiq.com (cadastro gratuito).
LOCATIONIQ_KEY=pk.sua_chave_aqui_do_locationiq
OPENWEATHER_API_KEY=
