<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Acesso à internet para carregar tiles do OpenStreetMap -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Localização precisa em primeiro plano -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!-- Notificações de trigger visíveis ao usuário (Android 13+/API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Permite exibir notificações em tela cheia (sobre a tela de bloqueio).
         Obrigatório no Android 14+ (API 34+) para qualquer uso de fullScreenIntent.
         Sem essa permissão o sistema descarta silenciosamente o fullScreenIntent. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT"/>

    <!-- Foreground service para manter o processo vivo quando o app é minimizado -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <!-- Tipo específico "location" exigido pelo Android 14+ para serviços com GPS -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <!-- Permite reiniciar o serviço após reboot do dispositivo -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- ── BLE Social (Sprint 7) ─────────────────────────────────────────── -->
    <!-- Android 12+ (API 31+): permissões granulares por operação BLE.
         neverForLocation = não usamos BLE scan para inferir localização (privacidade). -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"/>
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE"/>

    <!-- Android < 12: permissões legacy necessárias para BLE.
         maxSdkVersion="30" garante que não conflitem com as novas em Android 12+. -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30"/>

    <!-- Declara que o app usa BLE como funcionalidade principal -->
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true"/>

    <!-- Geofencing nativo em segundo plano — Android 10+ (API 29+) exige essa permissão
         para que o GeofenceReceiver seja acionado quando o app não está em primeiro plano.
         No Android 11+, o usuário concede via Configurações > Localização > "Sempre". -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>

    <!-- Microfone para reconhecimento de voz on-device (Sprint V2-Voz) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- Permite exibir janela flutuante sobre outros apps (V3 — botão global de voz).
         Requer Settings.ACTION_MANAGE_OVERLAY_PERMISSION no Android 6+ (API 23+).
         Adicionado preventivamente na V2 para que a permissão apareça no manifesto. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>

    <!-- Galeria de fotos para o perfil (image_picker) — Android 13+ usa READ_MEDIA_IMAGES -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- Fallback para Android 12 e anteriores -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <application
        android:label="sopro"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Foreground service do flutter_background_service.
             foregroundServiceType="location" exigido pelo Android 10+ para
             serviços que acessam GPS em segundo plano. -->
        <!-- tools:replace resolve o conflito com o manifest interno do
             flutter_background_service que também declara android:exported -->
        <service
            android:name="id.flutter.flutter_background_service.BackgroundService"
            android:foregroundServiceType="location"
            android:exported="false"
            tools:replace="android:exported"/>

        <!-- GeofenceReceiver — ativado pelo sistema Android ao detectar transições
             de geofence. android:exported="false": só o próprio sistema (via
             GeofencingClient PendingIntent) pode enviar Intents para este receiver. -->
        <receiver
            android:name=".GeofenceReceiver"
            android:exported="false"/>

        <!-- BootReceiver — re-registra geofences após reinicialização do dispositivo.
             O Android destrói todos os geofences do GeofencingClient no reboot;
             este receiver restaura-os lendo o banco SQLite diretamente.
             android:exported="true" é obrigatório para receber broadcasts do sistema. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>

        <!-- VoiceActionReceiver — recebe broadcasts do FloatingVoiceService para
             criar triggers quando o app está em background. Salva em SharedPreferences
             e inicia MainActivity para que o Flutter/Drift processe e salve no banco.
             android:exported="false": só o próprio app pode enviar este broadcast. -->
        <receiver
            android:name=".VoiceActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.sopro.sopro.VOICE_ACTION" />
            </intent-filter>
        </receiver>

        <!-- FloatingVoiceService — exibe botão flutuante de voz sobre outros apps.
             Requer SYSTEM_ALERT_WINDOW concedido pelo usuário (verificado em runtime).
             android:exported="false": só o próprio app pode iniciar este serviço. -->
        <service
            android:name=".FloatingVoiceService"
            android:exported="false"/>

        <!-- TransparentVoiceActivity — activity totalmente transparente (sem UI visível)
             que processa ações de voz do FloatingVoiceService (criar trigger/ambiente).
             noHistory=true: nunca entra no backstack do usuário.
             excludeFromRecents=true: não aparece na tela "App recentes".
             Usa Theme.Translucent para zero visibilidade; fecha após invokeMethod. -->
        <activity
            android:name=".TransparentVoiceActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:exported="false"/>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- url_launcher: necessário para abrir URLs https (WhatsApp, browser) no Android 11+ -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
