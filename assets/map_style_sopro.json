{
  "version": 8,
  "name": "Sopro Dark",
  "sources": {
    "ofm": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#11141A" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "ofm",
      "source-layer": "water",
      "paint": { "fill-color": "#256A8F" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "ofm",
      "source-layer": "waterway",
      "paint": { "line-color": "#256A8F", "line-width": 1 }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "ofm",
      "source-layer": "landcover",
      "paint": { "fill-color": "#0a1020", "fill-opacity": 0.6 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "ofm",
      "source-layer": "park",
      "paint": { "fill-color": "#1A3026", "fill-opacity": 0.8 }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "ofm",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#16203a",
        "fill-outline-color": "#26324f",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "ofm",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "paint": {
        "line-color": "#2B303A",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 18, 1.5],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "ofm",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "residential"],
      "paint": {
        "line-color": "#2B303A",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 18, 2]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "ofm",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "paint": {
        "line-color": "#2B303A",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 18, 5]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "ofm",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk", "motorway"],
      "paint": {
        "line-color": "#D6AA6C",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.5, 18, 7]
      }
    },
    {
      "id": "building-3d",
      "type": "fill-extrusion",
      "source": "ofm",
      "source-layer": "building",
      "minzoom": 14,
      "layout": { "visibility": "none" },
      "paint": {
        "fill-extrusion-color": "#1c2942",
        "fill-extrusion-height": [
          "interpolate", ["linear"], ["zoom"],
          14, 0,
          15.5, ["get", "render_height"]
        ],
        "fill-extrusion-base": ["get", "render_min_height"],
        "fill-extrusion-opacity": 0.92
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "ofm",
      "source-layer": "transportation_name",
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "symbol-placement": "line",
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "#D6AA6C",
        "text-halo-color": "#11141A",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "ofm",
      "source-layer": "place",
      "filter": ["in", "class", "village", "suburb", "quarter"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#a0b0d0",
        "text-halo-color": "#1a2535",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "ofm",
      "source-layer": "place",
      "filter": ["in", "class", "town", "city"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 11, 14, 15],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#dae2fd",
        "text-halo-color": "#1a2535",
        "text-halo-width": 2
      }
    }
  ]
}
