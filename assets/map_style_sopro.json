{
  "version": 8,
  "name": "Sopro Dark",
  "sources": {
    "ofm": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#30426e" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "ofm",
      "source-layer": "water",
      "paint": { "fill-color": "#1e2e52" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "ofm",
      "source-layer": "waterway",
      "paint": { "line-color": "#1e2e52", "line-width": 1 }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "ofm",
      "source-layer": "landcover",
      "paint": { "fill-color": "#2a3a5e", "fill-opacity": 0.5 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "ofm",
      "source-layer": "park",
      "paint": { "fill-color": "#2d4060", "fill-opacity": 0.7 }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "ofm",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "fill-color": "#243350",
        "fill-outline-color": "#1a2740",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "ofm",
      "source-layer": "transportation",
      "filter": ["in", "class", "path", "track"],
      "paint": {
        "line-color": "#3a4a6a",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 18, 1.5],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "ofm",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "residential"],
      "paint": {
        "line-color": "#4a5a7e",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.8, 18, 3]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "ofm",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "paint": {
        "line-color": "#7a6820",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 1, 18, 5]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "ofm",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk", "motorway"],
      "paint": {
        "line-color": "#c8a030",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.5, 18, 7]
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "ofm",
      "source-layer": "transportation_name",
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "symbol-placement": "line",
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "#c8a030",
        "text-halo-color": "#1a2535",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-village",
      "type": "symbol",
      "source": "ofm",
      "source-layer": "place",
      "filter": ["in", "class", "village", "suburb", "quarter"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11
      },
      "paint": {
        "text-color": "#a0b0d0",
        "text-halo-color": "#1a2535",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "ofm",
      "source-layer": "place",
      "filter": ["in", "class", "town", "city"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 11, 14, 15],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#dae2fd",
        "text-halo-color": "#1a2535",
        "text-halo-width": 2
      }
    }
  ]
}
